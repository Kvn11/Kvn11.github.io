width="327"
height="961"
srcset="https://Kvn11.github.io/p/intro-to-kernel-exploitation/img/usr_packet_hu86ddfb2dc1a7c28e225c5e327c098637_34150_480x0_resize_box_3.png 480w, https://Kvn11.github.io/p/intro-to-kernel-exploitation/img/usr_packet_hu86ddfb2dc1a7c28e225c5e327c098637_34150_1024x0_resize_box_3.png 1024w"
loading="lazy"
